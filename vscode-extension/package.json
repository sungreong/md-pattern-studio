{
  "name": "markdown-pattern-studio-preview",
  "displayName": "Markdown Pattern Studio Preview",
  "description": "Preview Markdown Pattern Studio CLI output in a VS Code webview.",
  "version": "0.1.10",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/markdown-pattern-studio-preview"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onView:mdStudioFileBrowser",
    "onCommand:mdStudioPreview.open",
    "onCommand:mdStudioPreview.refresh",
    "onCommand:mdStudioPreview.openTemplateBuilder",
    "onCommand:mdStudioPreview.openFileInViewer",
    "onCommand:mdStudioPreview.openFileInNewPanel",
    "onCommand:mdStudioPreview.transformMarkdownToHtml",
    "onCommand:mdStudioPreview.downloadSkillFolder",
    "onCommand:mdStudioPreview.diagnoseEnvironment",
    "onCommand:mdStudioFileBrowser.refresh",
    "onCommand:mdStudioFileBrowser.search"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mdStudioFileBrowserContainer",
          "title": "MD Studio File Browser",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "mdStudioFileBrowserContainer": [
        {
          "id": "mdStudioFileBrowser",
          "name": "Markdown Files",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "mdStudioPreview.open",
        "title": "MD Studio: Preview"
      },
      {
        "command": "mdStudioPreview.refresh",
        "title": "MD Studio: Refresh"
      },
      {
        "command": "mdStudioPreview.openTemplateBuilder",
        "title": "Template Builder",
        "icon": "$(combine)"
      },
      {
        "command": "mdStudioPreview.downloadSkillFolder",
        "title": "MD Studio: Download Skill Folder",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mdStudioPreview.diagnoseEnvironment",
        "title": "MD Studio: Diagnose Environment",
        "icon": "$(pulse)"
      },
      {
        "command": "mdStudioPreview.transformMarkdownToHtml",
        "title": "MD Studio: Transform Markdown to Styled HTML",
        "icon": "$(file-code)"
      },
      {
        "command": "mdStudioPreview.openFileInViewer",
        "title": "MD Studio: Open in Viewer",
        "icon": "$(open-preview)"
      },
      {
        "command": "mdStudioFileBrowser.refresh",
        "title": "MD Studio: Refresh File Browser",
        "icon": "$(refresh)"
      },
      {
        "command": "mdStudioPreview.openFileInNewPanel",
        "title": "Open in New Panel",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "mdStudioFileBrowser.search",
        "title": "MD Studio: Search Markdown Files",
        "icon": "$(search)"
      }
    ],
    "configuration": {
      "title": "Markdown Studio Preview",
      "properties": {
        "mdStudioPreview.autoOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh preview when a markdown file is saved."
        },
        "mdStudioPreview.cursorSyncOnSave": {
          "type": "boolean",
          "default": true,
          "description": "After save render, move preview to the section under the active cursor."
        },
        "mdStudioPreview.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Node.js executable path used to run scripts/md-to-html.mjs."
        },
        "mdStudioPreview.cliScriptPath": {
          "type": "string",
          "default": "scripts/md-to-html.mjs",
          "description": "CLI script path. Relative paths are resolved from workspace root. Absolute paths are also supported."
        },
        "mdStudioPreview.preferredViewMode": {
          "type": "string",
          "enum": [
            "auto",
            "slides",
            "stack"
          ],
          "default": "stack",
          "description": "Preferred presentation mode in preview webview. stack matches the web editor view by default."
        },
        "mdStudioPreview.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--standalone"
          ],
          "description": "Additional CLI arguments appended after --base-dir."
        },
        "mdStudioPreview.stripEmailDisclaimer": {
          "type": "boolean",
          "default": false,
          "description": "Remove common corporate email footer/disclaimer text before rendering markdown to HTML."
        },
        "mdStudioPreview.skillsDir": {
          "type": "string",
          "default": "claude_skills/skills",
          "description": "Path to the skills directory used by Template Builder. Relative paths are resolved from workspace root. Absolute paths are also supported."
        },
        "mdStudioPreview.defaultSkill": {
          "type": "string",
          "default": "md-presentation-composer",
          "description": "Preferred skill shown first in Template Builder when matching skills are available."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "mdStudioFileBrowser.search",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@1"
        },
        {
          "command": "mdStudioFileBrowser.refresh",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@2"
        },
        {
          "command": "mdStudioPreview.downloadSkillFolder",
          "when": "view == mdStudioFileBrowser",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "mdStudioPreview.open",
          "when": "resourceLangId == markdown",
          "group": "navigation@20"
        },
        {
          "command": "mdStudioPreview.refresh",
          "when": "resourceLangId == markdown",
          "group": "navigation@21"
        },
        {
          "command": "mdStudioPreview.openTemplateBuilder",
          "when": "resourceLangId == markdown",
          "group": "navigation@22"
        },
        {
          "command": "mdStudioPreview.transformMarkdownToHtml",
          "when": "resourceLangId == markdown",
          "group": "navigation@23"
        }
      ],
      "view/item/context": [
        {
          "command": "mdStudioPreview.openFileInNewPanel",
          "when": "view == mdStudioFileBrowser && viewItem == mdFile",
          "group": "inline"
        },
        {
          "command": "mdStudioPreview.openFileInNewPanel",
          "when": "view == mdStudioFileBrowser && viewItem == mdFile",
          "group": "navigation@1"
        },
        {
          "command": "mdStudioPreview.transformMarkdownToHtml",
          "when": "view == mdStudioFileBrowser && viewItem == mdFile",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "mdStudioPreview.transformMarkdownToHtml",
          "when": "resourceLangId == markdown",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "sync:bundle": "node ./tools/sync-cli-bundle.mjs",
    "smoke:bundled-cli": "node ./scripts/md-to-html.mjs --help",
    "build": "npm run sync:bundle && npm run smoke:bundled-cli && tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run build",
    "package:vsix": "vsce package"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE.md",
    "EXTENSION_GUIDE.md",
    "ai_skills/**",
    "node_modules/yazl/**",
    "node_modules/buffer-crc32/**",
    "scripts/md-to-html.mjs",
    "public/core/**",
    "public/document.css",
    "public/template-builder-vscode.html"
  ],
  "devDependencies": {
    "@types/node": "^20.17.24",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "yazl": "^2.5.1"
  }
}
